<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUAWARE OS | Blox Strike Edition</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap');

        body {
            margin: 0;
            padding: 0;
            background-color: #121212; 
            color: #ffffff;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        .glow {
            position: absolute;
            width: 300px;
            height: 300px;
            background: #76ff03; 
            filter: blur(150px);
            opacity: 0.2;
            z-index: -1;
        }

        .title {
            font-size: 5rem;
            font-weight: 900;
            margin: 0;
            letter-spacing: 5px;
            text-transform: uppercase;
            text-shadow: 0px 0px 20px rgba(118, 255, 3, 0.5); 
        }

        .title span {
            color: #76ff03; 
        }

        .subtitle {
            font-size: 1.2rem;
            color: #a0a0a0;
            margin-top: 10px;
            margin-bottom: 40px;
        }

        .button-container {
            display: flex;
            gap: 20px;
        }

        .btn {
            background-color: #1e1e1e;
            color: #ffffff;
            border: 2px solid #333;
            padding: 15px 40px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-primary {
            border-color: #76ff03;
            box-shadow: 0px 0px 15px rgba(118, 255, 3, 0.2);
        }

        .btn:hover {
            background-color: #76ff03;
            color: #000000;
            box-shadow: 0px 0px 30px rgba(118, 255, 3, 0.6);
            transform: translateY(-3px);
        }

        .footer {
            position: absolute;
            bottom: 20px;
            color: #555;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="glow"></div>
    <h1 class="title">LUA<span>WARE</span> OS</h1>
    <p class="subtitle">Roblox'un En Gelişmiş Prison Life Scripti</p>
    <div class="button-container">
        <a href="https://discord.gg/luaware" target="_blank" class="btn btn-primary">Discord'a Katıl</a>
        <a href="https://youtube.com/@LuawareScrpt" target="_blank" class="btn">YouTube</a>
    </div>
    <div class="footer">
        &copy; 2026 LUAWARE by NOXYORJ. Tüm Hakları Saklıdır.
    </div>
</body>
</html>
